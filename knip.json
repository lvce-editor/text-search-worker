{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "project": ["*.js"]
    },
    "packages/build": {
      "project": ["src/**/*.js", "src/**/*.ts"],
      "ignoreDependencies": ["@lvce-editor/verror", "esbuild"]
    },
    "packages/e2e": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/memory": {
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["playwright"]
    },
    "packages/about-view": {
      "entry": ["test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "packages/server": {
      "project": ["src/**/*.js"]
    }
  }
}
